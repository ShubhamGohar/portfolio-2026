# Sanity CMS (copy to .env.local for full CMS data in local dev)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Contact form
RESEND_API_KEY=re_your_key
CONTACT_EMAIL=your@email.com
# After verifying your domain in Resend, set e.g.:
# RESEND_FROM_EMAIL=Portfolio Contact <hello@shubhamgohar.com>

# Rate limiting (optional — create free DB at https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
